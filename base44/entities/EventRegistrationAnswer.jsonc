{
  "name": "EventRegistrationAnswer",
  "type": "object",
  "properties": {
    "registration_id": {
      "type": "string"
    },
    "field_id": {
      "type": "string"
    },
    "question_text": {
      "type": "string"
    },
    "answer_value": {
      "type": "string"
    }
  },
  "required": [
    "registration_id",
    "field_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.registration_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}