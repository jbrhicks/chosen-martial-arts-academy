{
  "name": "SeriesEnrollment",
  "type": "object",
  "properties": {
    "class_id": {
      "type": "string"
    },
    "class_name": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "series_start_date": {
      "type": "string",
      "format": "date"
    },
    "series_end_date": {
      "type": "string",
      "format": "date"
    },
    "enrolled_dates": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "cancelled"
      ],
      "default": "active"
    },
    "enrollment_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "class_id",
    "user_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}