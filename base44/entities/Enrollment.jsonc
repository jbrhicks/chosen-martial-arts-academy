{
  "name": "Enrollment",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "program": {
      "type": "string"
    },
    "program_id": {
      "type": "string"
    },
    "belt_rank": {
      "type": "string"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "cancelled",
        "waitlist"
      ],
      "default": "active"
    }
  },
  "required": [
    "user_email",
    "program",
    "start_date"
  ]
}