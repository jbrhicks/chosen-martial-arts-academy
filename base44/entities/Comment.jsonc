{
  "name": "Comment",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string"
    },
    "author_id": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_role": {
      "type": "string",
      "enum": [
        "student",
        "admin"
      ],
      "default": "student"
    },
    "content": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    },
    "is_flagged": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "post_id",
    "author_id",
    "content"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "student"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$and": [
        {
          "data.is_deleted": {
            "$ne": true
          }
        },
        {
          "$or": [
            {
              "user_condition": {
                "role": "student"
              }
            },
            {
              "user_condition": {
                "role": "admin"
              }
            }
          ]
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.author_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.author_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}