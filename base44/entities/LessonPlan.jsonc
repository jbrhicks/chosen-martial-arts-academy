{
  "name": "LessonPlan",
  "type": "object",
  "properties": {
    "program_id": {
      "type": "string"
    },
    "program_name": {
      "type": "string"
    },
    "target_date": {
      "type": "string",
      "format": "date"
    },
    "plan_content": {
      "type": "string"
    },
    "author_admin_id": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    }
  },
  "required": [
    "program_id",
    "target_date",
    "plan_content"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "is_instructor": true
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}